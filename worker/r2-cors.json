{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://opendesign.pages.dev",
          "http://localhost:5173"
        ],
        "methods": [
          "GET",
          "HEAD"
        ],
        "headers": [
          "*"
        ]
      },
      "exposeHeaders": [
        "Content-Length",
        "Content-Type",
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
